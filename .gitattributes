# Force LF line endings for all text files (prevents CRLF from Windows commits)
* text=auto eol=lf

# Explicitly mark source files
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.properties text eol=lf
*.toml text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.webp binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp3 binary
*.ogg binary
*.wav binary
*.wasm binary
*.nmd binary
*.jar binary
*.db binary
